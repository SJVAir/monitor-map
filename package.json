{
	"name": "@sjvair/monitor-map",
	"description": "SJVAir's interactive monitor map",
	"version": "3.0.5",
	"scripts": {
		"dev": "vite dev",
		"build:local": "PROD_MODE=local vite build",
		"build": "PROD_MODE=production vite build",
		"build:lib": "PROD_MODE=local svelte-package -i src/lib -o dist/lib",
		"preview": "vite preview",
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint ."
	},
	"type": "module",
	"svelte": "./dist/lib/index.js",
	"types": "./dist/lib/index.d.ts",
	"exports": {
		".": {
			"svelte": "./dist/lib/index.js",
			"types": "./dist/lib/index.d.ts",
			"default": "./dist/lib/index.js"
		}
	},
	"files": [
		"src/lib",
		"dist/lib"
	],
	"sideEffects": [
		"**/*.css"
	],
	"peerDependencies": {
		"@sveltejs/enhanced-img": "^0.11.0",
		"sv-router": "^0.16.2",
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@fontsource-variable/inter": "^5.2.8",
		"@sveltejs/enhanced-img": "^0.11.0",
		"@sveltejs/package": "^2.5.8",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@tailwindcss/vite": "^4.3.2",
		"@types/node": "^26.1.1",
		"eslint": "^10.6.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^17.7.0",
		"postcss": "^8.5.16",
		"prettier": "^3.9.4",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"shadcn-svelte": "^1.4.0",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.2",
		"tailwindcss": "^4.3.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.63.0",
		"vite": "^8.1.3"
	},
	"dependencies": {
		"@internationalized/date": "^3.12.2",
		"@lucide/svelte": "^1.23.0",
		"@maptiler/sdk": "^4.0.2",
		"@maptiler/weather": "^3.1.1",
		"@sjvair/sdk": "npm:@jsr/sjvair__sdk@^3.0.2",
		"@tstk/builtin-extensions": "npm:@jsr/tstk__builtin-extensions@^1.0.8",
		"@tstk/utils": "npm:@jsr/tstk__utils@^1.1.2",
		"@turf/area": "^7.3.5",
		"@turf/clusters-dbscan": "^7.3.5",
		"@turf/helpers": "^7.3.5",
		"@types/geojson": "^7946.0.16",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"color2k": "^2.0.4",
		"date-fns": "^4.4.0",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"uplot": "^1.6.32"
	},
	"keywords": [
		"svelte"
	],
	"allowScripts": {
		"sharp@0.34.5": true
	}
}
